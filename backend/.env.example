DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE"

# Required: at least 32 random characters.
JWT_SECRET="replace-with-a-long-random-secret"

# Required: 32 random bytes, base64-encoded.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
DATA_ENCRYPTION_KEY="replace-with-base64-key"

# Comma-separated origins allowed to call this API.
CORS_ORIGINS="http://localhost:8081,http://localhost:19006"

# Optional Twilio integration for SMS/voice alerts.
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM_NUMBER=""
